generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("TURSO_DATABASE_URL")
}

model McpServer {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  githubUrl   String?
  npmPackage  String?
  author      String?
  transport   String   @default("stdio")
  category    String   @default("other")
  stars       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  audits   Audit[]
  tools    ToolManifest[]
}

model Audit {
  id            String   @id @default(cuid())
  serverId      String
  version       String   @default("0.1.0")
  status        String   @default("clean")
  exitCode      Int      @default(0)
  manifestHash  String?
  auditLog      String?  @default("")
  submittedById String?
  createdAt     DateTime @default(now())

  server      McpServer @relation(fields: [serverId], references: [id])
  findings    Finding[]
  submittedBy User?     @relation(fields: [submittedById], references: [id])
}

model Finding {
  id          String   @id @default(cuid())
  auditId     String
  type        String
  severity    String   @default("high")
  description String
  detail      String?  @default("")
  toolName    String?
  createdAt   DateTime @default(now())

  audit Audit @relation(fields: [auditId], references: [id])
}

model ToolManifest {
  id          String   @id @default(cuid())
  serverId    String
  name        String
  description String
  inputSchema String?  @default("{}")
  createdAt   DateTime @default(now())

  server McpServer @relation(fields: [serverId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  githubId  String   @unique
  login     String   @unique
  name      String?
  email     String?
  image     String?
  createdAt DateTime @default(now())

  tokens ApiToken[]
  audits Audit[]
}

model ApiToken {
  id                   String    @id @default(cuid())
  userId               String
  name                 String
  tokenHash            String    @unique
  lastUsedAt           DateTime?
  rateLimitWindowStart DateTime?
  rateLimitCount       Int       @default(0)
  createdAt            DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
